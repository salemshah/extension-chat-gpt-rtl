{
  "manifest_version": 3,
  "name": "ChatGPT RTL Support",
  "version": "1.0.0",
  "description": "Automatic RTL text direction for Persian, Arabic, Hebrew, and Urdu in ChatGPT",

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    },
    "default_title": "ChatGPT RTL Support"
  },

  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js":  ["src/content.js"],
      "css": ["src/styles.css"],
      "run_at": "document_idle"
    }
  ],

  "permissions": ["storage"],

  "browser_specific_settings": {
    "gecko": {
      "id": "chatgpt-rtl-support@extension",
      "strict_min_version": "109.0"
    }
  }
}
